{
  "version": "0.0.0",
  "author": "Community for NL Design System",
  "description": "Architecture of NL Design System",
  "license": "EUPL-1.2",
  "name": "@nl-design-system-unstable/architectuur",
  "keywords": [
    "nl-design-system",
    "archimate",
    "xml"
  ],
  "private": true,
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "engines": {
    "//": "Update @types/node to match the highest node version here",
    "node": ">=24 <=25",
    "pnpm": "^11.4.0"
  },
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:nl-design-system/architectuur.git",
    "directory": "."
  },
  "scripts": {
    "build": "tsc --build && vite build",
    "dev": "vite",
    "lint": "pnpm run  --aggregate-output \"/^lint:.*/\"",
    "lint:css": "stylelint --allow-empty-input '**/*.{css,scss}'",
    "lint:js": "eslint",
    "lint:md": "markdownlint '**/*.md'",
    "lint:package-json": "npmPkgJsonLint .",
    "lint:package-lock": "pnpm ls --recursive",
    "lint:prettier": "prettier --check .",
    "lint:ts": "tsc --noEmit",
    "lint-fix": "pnpm run  --aggregate-output \"/^lint-fix:.*/\"",
    "lint-fix:css": "stylelint --allow-empty-input --fix '**/*.{css,scss}'",
    "lint-fix:js": "eslint --fix",
    "lint-fix:md": "markdownlint --fix '**/*.md'",
    "prepare": "husky",
    "prettier": "prettier --list-different --write .",
    "preview": "vite preview",
    "test": "exit 0",
    "update-patch": "npm-check-updates --configFileName .ncurc.patch.mjs",
    "update-minor": "npm-check-updates --configFileName .ncurc.minor.mjs",
    "update-major": "npm-check-updates --configFileName .ncurc.major.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@nl-design-system/eslint-config": "2.2.0",
    "@nl-design-system/tsconfig": "1.0.5",
    "@types/node": "24.12.4",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "markdownlint-cli": "0.48.0",
    "npm-check-updates": "22.2.9",
    "npm-package-json-lint": "10.4.0",
    "prettier": "3.8.3",
    "stylelint": "17.14.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1",
    "stylelint-use-logical": "2.1.3",
    "typescript": "5.9.3",
    "vite": "8.1.5"
  }
}
